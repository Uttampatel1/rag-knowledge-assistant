# --- LLM provider -----------------------------------------------------------
# "mock"   -> deterministic offline answer grounded in retrieved context (no key)
# "gemini" -> Google Gemini (requires GEMINI_API_KEY)
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Embeddings -------------------------------------------------------------
# "auto"                 -> use sentence-transformers if installed, else hashing
# "sentence-transformers"-> force sentence-transformers (downloads a small model)
# "hash"                 -> deterministic offline hashing embedder (no download)
EMBEDDINGS_BACKEND=auto
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval / chunking ---------------------------------------------------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
# Maximal Marginal Relevance: diversity-aware retrieval (less redundant chunks).
USE_MMR=false
MMR_LAMBDA=0.5      # 1.0 = pure relevance, 0.0 = max diversity
MMR_FETCH_K=20      # candidate pool MMR re-ranks down to TOP_K

# --- Storage ----------------------------------------------------------------
DATA_DIR=data
VECTOR_STORE_DIR=data/vector_store

# --- Observability ----------------------------------------------------------
LOG_LEVEL=INFO
